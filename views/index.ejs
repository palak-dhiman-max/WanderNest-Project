    <h4 class=" mb-2 ms-2 mt-1 price-title">Price range (per night)</h4>



    <div id="price-slider"></div>
    <input type="hidden" name="minPrice" id="minPriceInput">
<input type="hidden" name="maxPrice" id="maxPriceInput">

<div class="row mt-3">
  <div class="col">
    <div class="border rounded-3 p-2">
      <small>MINIMUM</small>
      <h4 id="minPrice" >2000</h4>
    </div>
  </div>

  <div class="col">
    <div class="border rounded-3 p-2">
      <small>MAXIMUM</small>
      <h4 id="maxPrice">200000</h4>
    </div>
  </div>
</div>

  </div> 

  <!-- COUNTRY -->

