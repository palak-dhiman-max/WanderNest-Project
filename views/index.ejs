<% layout("/layouts/boilerplate") %>

<style>

.filters::-webkit-scrollbar{
    display: none;
}

.filters{
    white-space: nowrap;
    scrollbar-width: none;
   
}


.filters div{
    min-width: 80px;
    cursor: pointer;
     
}

.filters i{
    font-size: 1.3rem;
}

.filter-wrapper{

    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgb(196, 189, 189);
    margin-bottom: 1.5rem;
   
    
}



#filters{
    display: flex;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    width: 50rem;
   
  
}

#filters::-webkit-scrollbar{
    display: none;
}

.filter{
    border-bottom: 2px solid transparent;
    min-width: 80px;
    flex-shrink: 0;
    margin-top: 1rem;
    opacity: 0.7;
    cursor: pointer;
   
   
}

.filter:hover{
   opacity: 1;
   border-bottom: 2px solid grey;
}

.scroll-btn{
    width: 35px;
    height: 35px;
    border: none;
    border-radius: 50%;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    z-index: 10;
    
}



.filter-btn{
   margin-left: 1rem;
   display: flex !important;
   justify-content: center;
   align-items: center;
   
}

.filter-btn:hover{
    background-color: rgb(195, 195, 195);

}

.card-text .tax ,.tax1{
    display: none;
}

/* FILTER MODAL */

.filter-section-title{
    
    font-weight: 600;
    margin-bottom: 1.5rem;
}

.filter-chip{
    font-size: 0.95rem;
   
    
    border-radius: 1rem;
    min-height: 44px;
}

.filter-chip i{
    font-size: 0.9rem;
}

.price-box{
    padding: 0.8rem 1rem;
}

.price-box small{
    font-size: 0.75rem;
    color: #6c757d;
}

.price-box h4{
    font-size: 1rem;
    margin: 0;
}

.modal-content{
    border-radius: 2rem;
}

.modal-footer{
    padding: 1.25rem 2rem;
}

.show-btn{
    padding: 0.3rem ;
    border-radius: 0.8rem;
    padding-left: 0.3rem;
    padding-right: 0.3rem;
}

.modal-content{
    height: 90vh;
}

.modal-body{
    overflow-y: auto;
}

.modal-body{
    overflow-y: auto;
    scrollbar-width: none;
}

.modal-body::-webkit-scrollbar{
    display: none;
}

.noUi-connect{
    background-color: black;
}

.noUi-handle {
    background: #ff385c;
    border: 2px solid #ff385c;
    border-radius: 100%;
    box-shadow: none;
}
.price-title ,.country-title,.guest-title,.property-title,.aminities-title ,.location-title{
    font-size: 1.2rem;
}


.btn-check:checked + .filter-chip{
    background-color: black;
    color: white;
    border-color: black;
}

</style>
<body>


