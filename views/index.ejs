</form>

</div>




</div>


    </div>
  </div>


</body>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/nouislider@15.8.1/dist/nouislider.min.js"></script>

<script>
   const filters = document.getElementById("filters");

function scrollLeftBtn() {
    filters.scrollBy({
        left: -250,
        behavior: "smooth"
    });
}

function scrollRightBtn() {
    filters.scrollBy({
        left: 250,
        behavior: "smooth"
    });
}




let taxtoggle = document.getElementById('switchCheckDefault');

let taxtoggle1 = document.getElementById('switchCheckMobile');
taxtoggle.addEventListener('click', () => {

    let tax1 = document.getElementsByClassName('tax1');
    let tax2 = document.getElementsByClassName('tax2');

    for (let i = 0; i < tax1.length; i++) {

        if (tax1[i].style.display !== "inline") {
            tax1[i].style.display = "inline";
            tax2[i].style.display = "none";
        } else {
            tax1[i].style.display = "none";
            tax2[i].style.display = "inline";
        }

    }
});

taxtoggle1.addEventListener('click', () => {

    let tax1 = document.getElementsByClassName('tax1');
    let tax2 = document.getElementsByClassName('tax2');

    for (let i = 0; i < tax1.length; i++) {

        if (tax1[i].style.display !== "inline") {
            tax1[i].style.display = "inline";
            tax2[i].style.display = "none";
        } else {
            tax1[i].style.display = "none";
            tax2[i].style.display = "inline";
        }

    }
});

const slider = document.getElementById('price-slider');

noUiSlider.create(slider, {
    start: [2000, 200000],
    connect: true,
    range: {
        min: 1000,
        max: 200000
    }
});

const minPrice = document.getElementById("minPrice");
const maxPrice = document.getElementById("maxPrice");

slider.noUiSlider.on('update', function(values) {
    minPrice.textContent = Math.round(values[0]);
    maxPrice.textContent = Math.round(values[1]);
});


const minPriceInput = document.getElementById("minPriceInput");
const maxPriceInput = document.getElementById("maxPriceInput");

slider.noUiSlider.on('update', function(values) {

    const min = Math.round(values[0]);
    const max = Math.round(values[1]);

    minPrice.textContent = min;
    maxPrice.textContent = max;

    minPriceInput.value = min;
    maxPriceInput.value = max;
});

</script>
